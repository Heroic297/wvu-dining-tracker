{
  "mcpServers": {
    "agent_handler": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "mcp-remote@latest",
        "https://agent-proxy.perplexity.ai/merge_mcp",
        "--header",
        "Authorization: Bearer ${AGENT_PROXY_TOKEN}"
      ]
    }
  }
}
