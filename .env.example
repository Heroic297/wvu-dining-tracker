# Copy to .env and fill in your values

# ─── Vite Client Variables ───────────────────────────────────────
VITE_SUPABASE_URL=https://[project-ref].supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Database ────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# ─── Auth ────────────────────────────────────────────────────────
JWT_SECRET=generate-with-openssl-rand-hex-32
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SESSION_SECRET=another-random-secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── AI / external APIs ──────────────────────────────────────────
# Groq AI (https://console.groq.com)
GROQ_API_KEY=gsk_...

# USDA FoodData Central (https://fdc.nal.usda.gov/api-guide.html)
USDA_API_KEY=DEMO_KEY

# ─── Wearables ───────────────────────────────────────────────────
# Fitbit (https://dev.fitbit.com/apps/new)
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=
FITBIT_REDIRECT_URI=http://localhost:5000/api/wearables/fitbit/callback

# Garmin (https://developer.garmin.com)
GARMIN_CLIENT_ID=
GARMIN_CLIENT_SECRET=
GARMIN_REDIRECT_URI=http://localhost:5000/api/wearables/garmin/callback

# ─── Internal / Server ───────────────────────────────────────────
CRON_SECRET=your-cron-secret
PORT=5000
NODE_ENV=development

# ─── MCP / Claude Configuration ──────────────────────────────────
# Token for the perplexity agent proxy (used in .mcp.json)
AUTH_TOKEN=your-perplexity-agent-proxy-token-here
# GitHub PAT for MCP server (if not inherited globally)
GITHUB_TOKEN=your-github-pat-here